// ─── Core export engine ───
async function captureTabAsPDFPages(targetPage, pdf, isFirst, onProgress){
  go(targetPage);
  await new Promise(r=>setTimeout(r,900)); // wait for charts to render

  const isDark = window.matchMedia('(prefers-color-scheme:dark)').matches;
  const bgColor = isDark ? '#1e1e1c' : '#ffffff';

  const element = document.querySelector('.dash');
  const canvas = await html2canvas(element, {
    scale: 2,
    useCORS: true,
    logging: false,
    backgroundColor: bgColor,
    windowWidth: 1200,
    ignoreElements: el => el.id === 'exportModal'
  });

  const pageWidth = pdf.internal.pageSize.getWidth();
  const pageHeight = pdf.internal.pageSize.getHeight();
  const margin = 8;
  const contentW = pageWidth - margin * 2;
  const contentH = pageHeight - margin * 2;

  const pxPerMm = canvas.width / contentW;
  const sliceHeightPx = Math.round(contentH * pxPerMm);
  const totalSlices = Math.ceil(canvas.height / sliceHeightPx);

  for (let i = 0; i < totalSlices; i++) {
    const sy = i * sliceHeightPx;
    const sh = Math.min(sliceHeightPx, canvas.height - sy);
    const sliceCanvas = document.createElement('canvas');
    sliceCanvas.width = canvas.width;
    sliceCanvas.height = sh;
    const ctx = sliceCanvas.getContext('2d');
    ctx.drawImage(canvas, 0, sy, canvas.width, sh, 0, 0, canvas.width, sh);
    const imgData = sliceCanvas.toDataURL('image/jpeg', 0.92);
    const sliceHmm = sh / pxPerMm;

    if (!isFirst || i > 0) pdf.addPage();
    isFirst = false;

    // White/dark background fill
    pdf.setFillColor(isDark ? '#1e1e1c' : '#ffffff');
    pdf.rect(0, 0, pageWidth, pageHeight, 'F');
    pdf.addImage(imgData, 'JPEG', margin, margin, contentW, sliceHmm);

    if (onProgress) onProgress(i + 1, totalSlices);
  }
  return false; // isFirst is now false
}

// ─── Export current tab ───
window.exportCurrent = async function(){
  const btn = document.getElementById('exportCurrentBtn');
  const label = page === 'overview' ? 'Overview' : page;
  showModal('กำลัง Export PDF...', `แท็บ: ${label}`);
  btn.classList.add('loading');

  try {
    const {jsPDF} = window.jspdf;
    const pdf = new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
    const savedPage = page;

    updateModal(10, `กำลัง render ${label}...`);
    await captureTabAsPDFPages(page, pdf, true, (slice, total) => {
      updateModal(10 + Math.round((slice/total)*85), `หน้า ${slice}/${total}`);
    });

    updateModal(100, 'บันทึกไฟล์...');
    await new Promise(r=>setTimeout(r,200));
    const dateStr = new Date().toISOString().split('T')[0];
    pdf.save(`OT-Dashboard_${label.replace(/ /g,'-')}_${dateStr}.pdf`);

    go(savedPage);
  } catch(err){
    console.error('Export error:', err);
    alert('Export ล้มเหลว: ' + err.message);
  } finally {
    btn.classList.remove('loading');
    hideModal();
  }
};

// ─── Export all tabs ───
window.exportAll = async function(){
  const btn = document.getElementById('exportAllBtn');
  const allTabs = ['overview', ...MONTHS];
  showModal('กำลัง Export PDF ทุกแท็บ...', `รวม ${allTabs.length} แท็บ`);
  btn.classList.add('loading');

  const savedPage = page;

  try {
    const {jsPDF} = window.jspdf;
    const pdf = new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
    let isFirst = true;

    for (let ti = 0; ti < allTabs.length; ti++) {
      const tab = allTabs[ti];
      const label = tab === 'overview' ? 'Overview' : tab;
      const basePct = Math.round((ti / allTabs.length) * 90);
      updateModal(basePct, `(${ti+1}/${allTabs.length}) ${label}...`);

      isFirst = await captureTabAsPDFPages(tab, pdf, isFirst, (slice, total) => {
        const p = basePct + Math.round((slice/total) * (90/allTabs.length));
        updateModal(p, `${label} — หน้า ${slice}/${total}`);
      });
    }

    updateModal(97, 'รวมไฟล์...');
    await new Promise(r=>setTimeout(r,200));
    const dateStr = new Date().toISOString().split('T')[0];
    pdf.save(`OT-Dashboard_ALL_${dateStr}.pdf`);

    updateModal(100, 'เสร็จแล้ว!');
    await new Promise(r=>setTimeout(r,400));
    go(savedPage);
  } catch(err){
    console.error('Export all error:', err);
    alert('Export ล้มเหลว: ' + err.message);
  } finally {
    btn.classList.remove('loading');
    hideModal();
  }
};


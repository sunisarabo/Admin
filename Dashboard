  const maxWeekly=Math.max(...weeklyTotals);
  const maxFlights=Math.max(...d.flightCounts);
  CH['mChart']=new Chart(document.getElementById('mChart'),{type:'bar',
    data:{labels:d.weeks,datasets:[{
      label:'Total OT Hours',data:weeklyTotals,backgroundColor:'#3b82f6',
      borderRadius:3,borderSkipped:false,yAxisID:'y',order:2,
      datalabels:{anchor:'end',align:'top',color:TC,font:{size:11,weight:600},formatter:v=>v!==null&&v!==undefined?fmtNum(v)+'h':'',offset:8,display:'auto'}
    },{
      label:'Number of Flights',data:d.flightCounts,type:'line',
      borderColor:'#ef4444',backgroundColor:'transparent',borderWidth:3,
      pointRadius:6,pointBackgroundColor:'#ef4444',pointBorderColor:'#fff',pointBorderWidth:2.5,
      tension:0.4,fill:false,yAxisID:'y1',order:1,
      datalabels:{anchor:'end',align:'top',color:'#ef4444',font:{size:10,weight:700},formatter:v=>v!==null&&v!==undefined?v.toLocaleString('en-US'):'',offset:8,display:'auto'}
    }]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{legend:{display:false},datalabels:{display:true},
        tooltip:{callbacks:{label:c=>{if(c.dataset.yAxisID==='y1')return c.dataset.label+': '+fmtNum(c.raw)+' flights';return c.dataset.label+': '+fmtNum(c.raw)+' hrs';}}}},
      scales:{x:{ticks:{color:TC,font:{size:10}},grid:{display:false}},
        y:{position:'left',min:0,max:Math.ceil(maxWeekly*1.15/1000)*1000,ticks:{color:TC,font:{size:10},callback:v=>fmtNum(v)+'h'},grid:{color:GC},title:{display:true,text:'OT Hours',color:TC,font:{size:11,weight:500}}},
        y1:{position:'right',min:0,max:Math.ceil(maxFlights*1.15/500)*500,ticks:{color:'#ef4444',font:{size:10},callback:v=>fmtNum(v)},grid:{display:false},title:{display:true,text:'Flights',color:'#ef4444',font:{size:11,weight:500}}}}}});

  const maxTot=Math.max(...TEAMS.map(t=>d.teams[t.code]?d.teams[t.code].hours.reduce((a,v)=>a+toMin(v),0):0));
  let tbl='<thead><tr><th>Team</th><th>Airlines</th>';
  d.weeks.forEach(w=>{const wl=w.split(':')[1].trim();tbl+=`<th colspan="2" style="text-align:center;border-right:0.5px solid var(--border)">${wl}</th>`;});
  tbl+='<th style="text-align:right">Total</th></tr><tr><th></th><th></th>';
  d.weeks.forEach(()=>{tbl+=`<th style="text-align:center;font-size:10px;font-weight:400;color:var(--text-tertiary)">OT hrs</th><th style="text-align:center;font-size:10px;font-weight:400;color:var(--text-tertiary);border-right:0.5px solid var(--border)">Flights</th>`;});
  tbl+='<th></th></tr></thead><tbody>';
  [...TEAMS].sort((a,b)=>{
    const ta=d.teams[a.code]?d.teams[a.code].hours.reduce((s,v)=>s+toMin(v),0):0;
    const tb=d.teams[b.code]?d.teams[b.code].hours.reduce((s,v)=>s+toMin(v),0):0;
    return tb-ta;
  }).forEach(t=>{
    if(!d.teams[t.code])return;
    const vals=d.teams[t.code].hours;
    const flights=d.teams[t.code].flights||[0,0,0,0];
    const tot=vals.reduce((a,v)=>a+toMin(v),0),pct=Math.round(tot/maxTot*100);
    tbl+=`<tr><td><span class="badge" style="background:${t.color}22;color:${t.color}">${t.name}</span></td>
      <td style="color:var(--text-secondary);font-size:11px;max-width:160px;overflow:hidden;text-overflow:ellipsis">${t.airlines}</td>`;
    vals.forEach((v,wi)=>{tbl+=`<td style="text-align:center;font-size:11px;font-weight:500">${v||'0:00'}</td><td style="text-align:center;font-size:11px;color:var(--text-secondary);border-right:0.5px solid var(--border)">${flights[wi].toLocaleString('en-US')}</td>`;});
    tbl+=`<td style="text-align:right"><div class="barcell"><div class="barbg"><div class="barfill" style="width:${pct}%;background:${t.color}"></div></div><span style="min-width:55px;text-align:right;font-weight:500">${fmtH(tot)}</span></div></td></tr>`;
  });
  const wt=d.weeks.map((w,wi)=>TEAMS.reduce((a,t)=>a+(d.teams[t.code]?toMin(d.teams[t.code].hours[wi]):0),0));
  tbl+='<tr class="total-row"><td colspan="2">Grand Total</td>';
  wt.forEach((v,wi)=>{tbl+=`<td style="text-align:center;font-weight:500">${fmtH(v)}</td><td style="text-align:center;font-weight:500;border-right:0.5px solid var(--border)">${d.flightCounts[wi].toLocaleString('en-US')}</td>`;});
  tbl+=`<td style="text-align:right;font-weight:500">${fmtH(gt)}</td></tr></tbody>`;
  document.getElementById('mtbl').innerHTML=tbl;
}

function renderTabs(){
  document.getElementById('tabs').innerHTML=
    `<button class="tab ov${page==='overview'?' active':''}" onclick="go('overview')">Overview</button>`+
    MONTHS.map(m=>`<button class="tab${page===m?' active':''}" onclick="go('${m}')">${m}</button>`).join('');
}

window.go=function(p){
  page=p;
  Object.keys(CH).forEach(id=>dc(id));
  renderTabs();
  if(p==='overview') renderOverview();
  else renderMonth(p);
};

renderTabs();
renderOverview();

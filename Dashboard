function toMin(s){if(!s||s==='0:00')return 0;const p=s.split(':');return parseInt(p[0])*60+parseInt(p[1]);}
function fmtH(m){const h=Math.floor(m/60),mn=m%60;return h.toLocaleString('en-US')+':'+String(mn).padStart(2,'0');}
function fmtNum(v){return parseFloat(v).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:1});}
function tmTotal(mk,tc){return DATA[mk].teams[tc]?DATA[mk].teams[tc].hours.reduce((a,v)=>a+toMin(v),0):0;}
function mTotal(mk){return TEAMS.reduce((a,t)=>a+tmTotal(mk,t.code),0);}
function allTotal(){return MONTHS.reduce((a,mk)=>a+mTotal(mk),0);}
function teamAll(tc){return MONTHS.reduce((a,mk)=>a+tmTotal(mk,tc),0);}
function topTm(mk){let mx=0,nm='',cl='';TEAMS.forEach(t=>{const m=tmTotal(mk,t.code);if(m>mx){mx=m;nm=t.name;cl=t.color;}});return{name:nm,min:mx,color:cl};}
function topTmAll(){let mx=0,nm='';TEAMS.forEach(t=>{const m=teamAll(t.code);if(m>mx){mx=m;nm=t.name;}});return{name:nm,min:mx};}
function peakMo(){let mx=0,nm='';MONTHS.forEach(mk=>{const g=mTotal(mk);if(g>mx){mx=g;nm=mk;}});return{name:nm,min:mx};}
function dc(id){if(CH[id]){CH[id].destroy();delete CH[id];}}

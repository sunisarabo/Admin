*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;}
:root{
  --bg-primary:#ffffff;--bg-secondary:#f5f5f3;--bg-info:#e6f1fb;
  --text-primary:#1a1a18;--text-secondary:#5f5e5a;--text-tertiary:#888780;--text-info:#185fa5;
  --border:rgba(0,0,0,0.12);--border-md:rgba(0,0,0,0.22);--radius-md:8px;--radius-lg:12px;
  --font:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}
@media(prefers-color-scheme:dark){:root{
  --bg-primary:#1e1e1c;--bg-secondary:#2a2a28;--bg-info:#0c2e50;
  --text-primary:#f0ede8;--text-secondary:#b4b2a9;--text-tertiary:#888780;--text-info:#85b7eb;
  --border:rgba(255,255,255,0.1);--border-md:rgba(255,255,255,0.18);
}}
body{font-family:var(--font);background:var(--bg-secondary);color:var(--text-primary);padding:16px;min-height:100%;overflow-y:auto;}
.app-wrapper{width:100%;height:100%;display:flex;flex-direction:column;}
.dash{max-width:1200px;margin:0 auto;width:100%;flex:1;}
.header{margin-bottom:1.5rem;}
.header h1{font-size:22px;font-weight:500;color:var(--text-primary);}
.header p{font-size:13px;color:var(--text-secondary);margin-top:4px;}
.tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1.5rem;overflow-x:auto;}
.tab{padding:6px 16px;border-radius:var(--radius-md);border:0.5px solid var(--border);font-size:13px;cursor:pointer;color:var(--text-secondary);background:var(--bg-primary);transition:all .15s;font-family:var(--font);white-space:nowrap;}
.tab:hover{border-color:var(--border-md);color:var(--text-primary);}
.tab.active{background:var(--bg-info);color:var(--text-info);border-color:transparent;font-weight:500;}
.tab.ov.active{background:#1a1a18;color:#f5f5f3;border-color:transparent;}
@media(prefers-color-scheme:dark){.tab.ov.active{background:#f0ede8;color:#1a1a18;}}
.g4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-bottom:1.5rem;}
.g5{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;margin-bottom:1rem;}
@media(max-width:1024px){.g4,.g5{grid-template-columns:repeat(2,1fr);}}
@media(max-width:640px){.g4,.g5{grid-template-columns:1fr;}.header{flex-direction:column;}}
.metric{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);padding:14px 16px;}
.metric-label{font-size:12px;color:var(--text-secondary);margin-bottom:5px;}
.metric-val{font-size:20px;font-weight:500;color:var(--text-primary);}
.metric-sub{font-size:11px;color:var(--text-tertiary);margin-top:3px;}
.card{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem 1.5rem;margin-bottom:1rem;overflow:hidden;}
.card-title{font-size:14px;font-weight:500;color:var(--text-primary);margin-bottom:14px;}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
table{width:100%;border-collapse:collapse;font-size:12px;}
th{font-size:11px;font-weight:500;color:var(--text-secondary);text-align:left;padding:7px 8px;border-bottom:0.5px solid var(--border);white-space:nowrap;}
td{padding:7px 8px;border-bottom:0.5px solid var(--border);color:var(--text-primary);white-space:nowrap;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--bg-secondary);}
.badge{font-size:11px;font-weight:500;padding:2px 8px;border-radius:4px;display:inline-block;}
.total-row td{font-weight:500;background:var(--bg-secondary);}
.barcell{display:flex;align-items:center;gap:8px;}
.barbg{height:6px;border-radius:3px;background:var(--border);flex:1;min-width:50px;}
.barfill{height:6px;border-radius:3px;}
.leg{display:flex;flex-wrap:wrap;gap:10px 16px;margin-top:14px;font-size:11px;}
.legitem{display:flex;align-items:center;gap:5px;color:var(--text-secondary);}
.legdot{width:10px;height:10px;border-radius:2px;flex-shrink:0;}

/* ─── Export Button Group ─── */
.export-group{display:flex;gap:6px;align-items:center;flex-shrink:0;}
.pdf-export-btn{
  padding:7px 13px;border-radius:var(--radius-md);border:0.5px solid var(--border);
  font-size:12px;cursor:pointer;background:var(--bg-primary);color:var(--text-primary);
  transition:all .15s;font-family:var(--font);display:inline-flex;align-items:center;
  gap:5px;font-weight:500;white-space:nowrap;
}
.pdf-export-btn:hover{border-color:var(--border-md);background:var(--bg-secondary);}
.pdf-export-btn.loading{opacity:0.55;cursor:not-allowed;pointer-events:none;}
.pdf-export-btn.btn-all{
  background:var(--bg-info);color:var(--text-info);border-color:var(--text-info);
  opacity:0.85;
}
.pdf-export-btn.btn-all:hover{opacity:1;}

/* ─── Export Progress Modal ─── */
#exportModal{
  display:none;position:fixed;inset:0;z-index:9999;
  background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);
  align-items:center;justify-content:center;
}
#exportModal.show{display:flex;}
.export-modal-box{
  background:var(--bg-primary);border:0.5px solid var(--border-md);
  border-radius:var(--radius-lg);padding:28px 32px;min-width:300px;text-align:center;
  box-shadow:0 12px 40px rgba(0,0,0,0.2);
}
.export-modal-title{font-size:15px;font-weight:500;color:var(--text-primary);margin-bottom:6px;}
.export-modal-sub{font-size:12px;color:var(--text-secondary);margin-bottom:20px;}
.export-progress-bar-bg{height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.export-progress-bar-fill{height:4px;background:#3b82f6;border-radius:2px;transition:width .3s ease;}
.export-modal-step{font-size:11px;color:var(--text-tertiary);margin-top:10px;}

/* ─── Print Styles ─── */
@media print{
  body{background:white !important;padding:0 !important;}
  .app-wrapper{background:white !important;}
  .header{page-break-after:avoid;}
  .card{page-break-inside:avoid;border:1px solid #eee !important;margin-bottom:16px !important;}
  .tabs,.export-group{display:none !important;}
  table{font-size:10px !important;}
  th,td{padding:4px !important;}
  canvas{max-width:100% !important;height:auto !important;}
}
